# ─────────────────────────────────────────────
#  API Automation Framework — Environment Config
#  Replace these values before running the framework
# ─────────────────────────────────────────────

# Base URL for REST APIs (used via {{API_BASE_URL}} in test cases)
API_BASE_URL=https://jsonplaceholder.typicode.com

# Authorization token (used via {{AUTH_TOKEN}} in headers)
AUTH_TOKEN=my-secret-bearer-token

# SOAP service base URL (used via {{SOAP_BASE_URL}} in SOAP test cases)
SOAP_BASE_URL=http://webservices.oorsprong.org/websamples.countryinfo/CountryInfoService.wso
